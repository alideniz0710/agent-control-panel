DATABASE_URL="file:./dev.db"

# LLM provider keys — at least one is required.
# anthropic-api and claude-code-agent backends need ANTHROPIC_API_KEY.
# openrouter and openrouter-code-agent backends need OPENROUTER_API_KEY.
ANTHROPIC_API_KEY=""
OPENROUTER_API_KEY=""

# Shared secret for POST /api/webhook — callers pass this as
# Authorization: Bearer <value>. Generate with: openssl rand -hex 32
# Leave blank to disable the webhook endpoint.
WEBHOOK_SECRET=""

# Optional bypass token for the public-access middleware. With this
# set, you can hit ANY route (UI or admin API) from a non-tailnet
# machine by sending Authorization: Bearer <ADMIN_TOKEN>. Leave blank
# to lock public access down to /api/webhook only.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=""

# Required for the `telegram` executor backend (notification sink).
# Bot token from @BotFather, chat id from any of the chat-id helper bots.
# TELEGRAM_CHAT_ID is the default chat — agents can override per-step
# via tools = { "chatId": "<other-chat>" }.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Outbound heartbeat for external uptime monitoring.
# Sign up at healthchecks.io (free), create a check, copy its ping URL
# (e.g., https://hc-ping.com/<uuid>) here. Panel pings every 5 minutes.
# Configure the check's grace period at healthchecks.io and add a
# Telegram integration there to get alerts when pings stop.
# Leave blank to skip monitoring (panel still runs, you just don't get
# alerted if it dies).
HEALTHCHECKS_URL=""

# Override the scheduler's cron timezone. Defaults to Europe/Istanbul
# so morning/evening briefs fire at correct local time regardless of
# where the host machine's clock is set.
# SCHEDULER_TZ="Europe/Istanbul"
